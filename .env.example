# ===========================================
# Jogy Backend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# ---- Application ----
APP_NAME=Jogy
DEBUG=true                  # Set to false in production

# ---- Database (PostgreSQL + PostGIS) ----
# Local development:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jogy
# Docker Compose production (auto-overridden in docker-compose.prod.yml):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@postgres:5432/jogy
DATABASE_ECHO=false

# Docker Compose variables (used by postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres   # CHANGE in production!
POSTGRES_DB=jogy

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=              # Set a password in production

# ---- JWT ----
JWT_SECRET_KEY=your-super-secret-key-change-in-production   # MUST change! Use: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- API Security ----
API_SIGNATURE_SECRET=your-api-signature-secret-change-in-production  # MUST change!
SIGNATURE_MIDDLEWARE_ENABLED=false   # Enable when Flutter app implements request signing
RATE_LIMIT_MIDDLEWARE_ENABLED=true

# ---- Rate Limiting (requests per second) ----
RATE_LIMIT_DISCOVER=10
RATE_LIMIT_LOCATION_SYNC=5

# ---- Location ----
LOCATION_FUZZY_METERS=100

# ---- SMTP (Email Verification) ----
# Gmail example (need to enable "App Passwords" in Google Account):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Jogy

# QQ Mail example:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-qq-number@qq.com
# SMTP_PASSWORD=your-authorization-code
# SMTP_FROM_NAME=Jogy
